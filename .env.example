# ─── Banco de dados ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/pnsp

# ─── Autenticação / JWT ───────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-with-at-least-32-chars

# ─── OAuth (Manus) ────────────────────────────────────────────────────────────
VITE_APP_ID=your-app-id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://auth.manus.im

# ─── Proprietário da plataforma ───────────────────────────────────────────────
OWNER_OPEN_ID=owner-open-id
OWNER_NAME=Nome do Proprietário

# ─── Forge API (IA / mapas / imagens) ─────────────────────────────────────────
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your-server-side-forge-key
VITE_FRONTEND_FORGE_API_KEY=your-frontend-forge-key
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
